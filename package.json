{
  "name": "@toil/vk-audio",
  "author": "Toil",
  "description": "Library for using Modern VK Audio API",
  "version": "0.0.5",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ilyhalight/vk-audio/issues"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "homepage": "https://github.com/ilyhalight/vk-audio#readme",
  "keywords": [
    "vk",
    "vkontakte",
    "audio",
    "client",
    "music",
    "vkmusic"
  ],
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsc-esm-fix": "^3.1.2",
    "typedoc": "^0.28.20",
    "typedoc-plugin-missing-exports": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:bun": "bun run ./scripts/build.ts",
    "build:doc": "typedoc --options typedoc.json --tsconfig tsconfig.build.json",
    "build:all": "bun build:bun && bun build:doc",
    "lint": "bunx oxlint",
    "lint:fix": "bunx oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "require": "./dist/client.js",
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./types/*": {
      "require": "./dist/types/*.js",
      "import": "./dist/types/*.js",
      "types": "./dist/types/*.d.ts"
    },
    "./utils/*": {
      "require": "./dist/utils/*.js",
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    }
  }
}
